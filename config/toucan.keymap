#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

// Adding pointing.h to be able to right and middle click
// https://zmk.dev/docs/keymaps/behaviors/mouse-emulation
#include <dt-bindings/zmk/pointing.h>

#define LAYER_macOS 0
#define LAYER_Windows 1
#define LAYER_Nav 2
#define LAYER_Symb 3
#define LAYER_Subl 4
#define LAYER_Apps 5
#define LAYER_Sesss 6
#define LAYER_Systm 7
#define LAYER_Yabai 8
#define LAYER_Raycast 9
#define LAYER_Letters 10
#define LAYER_Obs 11
#define LAYER_Bluetooth 12
#define LAYER_Obspos 13
#define LAYER_Work 14
#define LAYER_Block 15

#define KEYS_L 0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29
#define KEYS_R 6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35
#define THUMBS 36 37 38 39 40 41
#define HRM_PRIOR_IDLE_MS 125

/ {
    behaviors {
        // Testing urob's timeless home-row mods:
        // https://github.com/urob/zmk-config#timeless-homerow-mods
        // Cross-hand shortcuts can resolve immediately; same-hand shortcuts still
        // require holding past tapping-term-ms before pressing the next key.
        hrm_l: hrm_l {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            // How long a plain hold waits before becoming the modifier.
            // Cross-hand shortcuts can still resolve sooner via balanced + hold-trigger-key-positions.
            tapping-term-ms = <300>;
            bindings = <&kp>, <&kp>;
            flavor = "balanced";
            // If this HRM is tapped and quickly pressed again, keep the second press as a tap.
            // Useful for repeating letters without the second press becoming the modifier.
            quick-tap-ms = <300>;
            // If pressed within this window after a normal key, force a tap so fast typing stays immediate.
            // Lower this if intended HRM shifts/mods are blocked while typing quickly;
            // raise it if fast rolls accidentally trigger modifiers.
            require-prior-idle-ms = <HRM_PRIOR_IDLE_MS>;
            hold-trigger-key-positions = <KEYS_R THUMBS>;
            hold-trigger-on-release;
        };

        hrm_r: hrm_r {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <300>;
            bindings = <&kp>, <&kp>;
            flavor = "balanced";
            quick-tap-ms = <300>;
            require-prior-idle-ms = <HRM_PRIOR_IDLE_MS>;
            hold-trigger-key-positions = <KEYS_L THUMBS>;
            hold-trigger-on-release;
        };

        // Windows keeps faster timing than macOS, split by hand so positional
        // hold-trigger keys can remain opposite-hand only.
        hrm_w_l: hrm_w_l {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&kp>, <&kp>;
            flavor = "balanced";
            quick-tap-ms = <250>;
            require-prior-idle-ms = <HRM_PRIOR_IDLE_MS>;
            hold-trigger-key-positions = <KEYS_R THUMBS>;
            hold-trigger-on-release;
            retro-tap;
        };

        hrm_w_r: hrm_w_r {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <250>;
            bindings = <&kp>, <&kp>;
            flavor = "balanced";
            quick-tap-ms = <250>;
            require-prior-idle-ms = <HRM_PRIOR_IDLE_MS>;
            hold-trigger-key-positions = <KEYS_L THUMBS>;
            hold-trigger-on-release;
            retro-tap;
        };

        my_mt: my_mt {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <300>;
            bindings = <&kp>, <&kp>;
        };

        my_lt: my_lt {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <300>;
            bindings = <&mo>, <&kp>;
        };

        my_mtw: my_mtw {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        h_third_app: h_third_app {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <300>;
            bindings = <&third_app>, <&kp>;
        };

    };

    macros {
        third_app: third_app {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <40>;
            tap-ms = <40>;
            bindings
                = <&macro_press &kp LGUI>
                , <&macro_tap &kp TAB &kp TAB>
                , <&macro_release &kp LGUI>
                ;
        };

    };

#define TRANSITION_COMBO_TIMEOUT_MS 35
#define TRANSITION_COMBO_PRIOR_IDLE_MS 125

    combos {
        compatible = "zmk,combos";

        combo_mac_tab_ret {
            // Both keys must be pressed within this window.
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            // Avoids accidental combos during fast typing/rolls.
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            // Keeps hold-tap combos held until both combo keys are released.
            slow-release;
            // Physical positions for W and E.
            key-positions = <2 3>;
            // Only active on macOS, so W+E can mean something else on other layers.
            layers = <LAYER_macOS>;
            // Reuses my existing hold-tap: hold sends RET, tap sends TAB.
            bindings = <&my_mt RET TAB>;
        };

        combo_win_tab_ret {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            slow-release;
            key-positions = <2 3>;
            layers = <LAYER_Windows>;
            bindings = <&my_mtw RET TAB>;
        };

        combo_sd_esc {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            slow-release;
            key-positions = <14 15>;
            layers = <LAYER_macOS LAYER_Windows>;
            bindings = <&kp ESC>;
        };

        combo_df_space {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <15 16>;
            layers = <LAYER_macOS LAYER_Windows>;
            bindings = <&kp SPACE>;
        };

        combo_bslh {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <8 9>;
            layers = <LAYER_macOS LAYER_Windows>;
            bindings = <&kp BSLH>;
        };

        combo_sqt {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <20 21>;
            layers = <LAYER_macOS LAYER_Windows>;
            bindings = <&kp SQT>;
        };

        combo_sym_under {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <2 3>;
            layers = <LAYER_Symb>;
            bindings = <&kp LS(MINUS)>;
        };

        combo_sym_tilde {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <14 15>;
            layers = <LAYER_Symb>;
            bindings = <&kp LS(GRAVE)>;
        };

        combo_sym_plus {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <26 27>;
            layers = <LAYER_Symb>;
            bindings = <&kp LS(EQUAL)>;
        };

        combo_sym_minus {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <8 9>;
            layers = <LAYER_Symb>;
            bindings = <&kp MINUS>;
        };

        combo_sym_grave {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <20 21>;
            layers = <LAYER_Symb>;
            bindings = <&kp GRAVE>;
        };

        combo_sym_equal {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <32 33>;
            layers = <LAYER_Symb>;
            bindings = <&kp EQUAL>;
        };

        combo_apps_r_top {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <8 9>;
            layers = <LAYER_Apps>;
            bindings = <&kp LS(LC(F11))>;
        };

        combo_apps_r_home {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <20 21>;
            layers = <LAYER_Apps>;
            bindings = <&kp LC(LA(F13))>;
        };

        combo_apps_r_bottom {
            timeout-ms = <TRANSITION_COMBO_TIMEOUT_MS>;
            require-prior-idle-ms = <TRANSITION_COMBO_PRIOR_IDLE_MS>;
            key-positions = <32 33>;
            layers = <LAYER_Apps>;
            bindings = <&kp LC(LA(F11))>;
        };

    };
};

/ {

    keymap {
        compatible = "zmk,keymap";

        layer_macOS {
            display-name = "mac";
            bindings = <
//    ┌──────────────────┬──────────────────────┬────────────────────────┬──────────────────┬──────────────────────────┬─────────────────────────┐                ┌─────────────────────┬─────────────────────────┬───────────────┬────────────────────────────────────┬───────────────┬──────────────────┐
//    │ mo laltYER_Block │ &my_lt laltYER_Nav Q │ &my_lt laltYER_Systm W │ &my_mt lalt(E) E │ &my_mt lctl(lgui(f19)) R │ &my_mt lgui(lalt(f1)) T │                │          Y          │    &my_mt lgui(Z) U     │       I       │ &my_mt lgui(lctl(lalt(lsft(Z)))) O │       P       │ mo laltYER_Block │
//    ├──────────────────┼──────────────────────┼────────────────────────┼──────────────────┼──────────────────────────┼─────────────────────────┤                ├─────────────────────┼─────────────────────────┼───────────────┼────────────────────────────────────┼───────────────┼──────────────────┤
//    │ mo laltYER_Block │    &hrm_l lctl A     │     &hrm_l lsft S      │  &hrm_l lalt D   │      &hrm_l lgui F       │    &my_mt lctl(Z) G     │                │  &h_third_app 0 H   │      &hrm_r rgui J      │ &hrm_r ralt K │           &hrm_r rsft L            │ &hrm_r rctl ; │ mo laltYER_Block │
//    ├──────────────────┼──────────────────────┼────────────────────────┼──────────────────┼──────────────────────────┼─────────────────────────┤                ├─────────────────────┼─────────────────────────┼───────────────┼────────────────────────────────────┼───────────────┼──────────────────┤
//    │ mo laltYER_Block │  &my_mt lgui(tab) Z  │    &my_mt lgui(`) X    │ &my_mt lgui(C) C │     &my_mt lgui(V) V     │ &my_mt lgui(lalt(f8)) B │                │  &my_mt lalt(N) N   │ &my_mt lgui(lalt(f9)) M │       ,       │ &my_mt lgui(lctl(lalt(lsft(6)))) . │       /       │ mo laltYER_Block │
//    └──────────────────┴──────────────────────┴────────────────────────┴──────────────────┼──────────────────────────┼─────────────────────────┼──────┐   ┌─────┼─────────────────────┼─────────────────────────┼───────────────┴────────────────────────────────────┴───────────────┴──────────────────┘
//                                                                                          │                          │  lt laltYER_Symb bspc   │ lsft │   │ spc │ lt laltYER_Subl ent │                         │
//                                                                                          └──────────────────────────┴─────────────────────────┴──────┘   └─────┴─────────────────────┴─────────────────────────┘
  &mo LAYER_Block   &my_lt LAYER_Nav Q   &my_lt LAYER_Systm W   &my_mt LA(E) E   &my_mt LC(LG(F19)) R   &my_mt LG(LA(F1)) T                               &kp Y                &my_mt LG(Z) U        &kp I           &my_mt LG(LC(LA(LS(Z)))) O     &kp P               &mo LAYER_Block
  &mo LAYER_Block   &hrm_l LCTRL A       &hrm_l LSHFT S         &hrm_l LALT D    &hrm_l LGUI F          &my_mt LC(Z) G                                    &h_third_app 0 H     &hrm_r RGUI J         &hrm_r RALT K   &hrm_r RSHFT L                 &hrm_r RCTRL SEMI   &mo LAYER_Block
  &mo LAYER_Block   &my_mt LG(TAB) Z     &my_mt LG(GRAVE) X     &my_mt LG(C) C   &my_mt LG(V) V         &my_mt LG(LA(F8)) B                               &my_mt LA(N) N       &my_mt LG(LA(F9)) M   &kp COMMA       &my_mt LG(LC(LA(LS(6)))) DOT   &kp FSLH            &mo LAYER_Block
                                                                                 &none                  &lt LAYER_Symb BSPC   &kp LSHFT       &kp SPACE   &lt LAYER_Subl RET   &none
            >;
        };

        layer_Windows {
            display-name = "WNDS";
            bindings = <
//    ┌──────────────────┬────────────────────────────────┬────────────────────────────────┬───────────────────┬───────────────────────────┬──────────────────────────┐                ┌─────────────────────┬──────────────────┬─────────────────┬─────────────────┬─────────────────┬──────────────────┐
//    │ mo laltYER_Block │        lt laltYER_Nav Q        │       lt laltYER_Systm W       │         E         │ &my_mtw lctl(lgui(f19)) R │ &my_mtw lgui(lalt(f1)) T │                │          Y          │ &my_mt lctl(Z) U │        I        │        O        │        P        │ mo laltYER_Block │
//    ├──────────────────┼────────────────────────────────┼────────────────────────────────┼───────────────────┼───────────────────────────┼──────────────────────────┤                ├─────────────────────┼──────────────────┼─────────────────┼─────────────────┼─────────────────┼──────────────────┤
//    │ mo laltYER_Block │        &hrm_w_l lctl A         │        &hrm_w_l lsft S         │  &hrm_w_l lgui D  │      &hrm_w_l lalt F      │            G             │                │          H          │ &hrm_w_r ralt J  │ &hrm_w_r rgui K │ &hrm_w_r rsft L │ &hrm_w_r rctl ; │ mo laltYER_Block │
//    ├──────────────────┼────────────────────────────────┼────────────────────────────────┼───────────────────┼───────────────────────────┼──────────────────────────┤                ├─────────────────────┼──────────────────┼─────────────────┼─────────────────┼─────────────────┼──────────────────┤
//    │ mo laltYER_Block │ &my_mtw lsft(lalt(lgui(f6))) Z │ &my_mtw lsft(lalt(lgui(f7))) X │ &my_mtw lctl(C) C │     &my_mtw lctl(V) V     │            B             │                │          N          │        M         │        ,        │        .        │        /        │ mo laltYER_Block │
//    └──────────────────┴────────────────────────────────┴────────────────────────────────┴───────────────────┼───────────────────────────┼──────────────────────────┼──────┐   ┌─────┼─────────────────────┼──────────────────┼─────────────────┴─────────────────┴─────────────────┴──────────────────┘
//                                                                                                             │                           │   lt laltYER_Symb bspc   │ lsft │   │ spc │ lt laltYER_Subl ent │                  │
//                                                                                                             └───────────────────────────┴──────────────────────────┴──────┘   └─────┴─────────────────────┴──────────────────┘
  &mo LAYER_Block   &lt LAYER_Nav Q            &lt LAYER_Systm W          &kp E             &my_mtw LC(LG(F19)) R   &my_mtw LG(LA(F1)) T                               &kp Y                &my_mt LC(Z) U    &kp I             &kp O              &kp P                 &mo LAYER_Block
  &mo LAYER_Block   &hrm_w_l LCTRL A           &hrm_w_l LSHFT S           &hrm_w_l LGUI D   &hrm_w_l LALT F         &kp G                                              &kp H                &hrm_w_r RALT J   &hrm_w_r RGUI K   &hrm_w_r RSHFT L   &hrm_w_r RCTRL SEMI   &mo LAYER_Block
  &mo LAYER_Block   &my_mtw LS(LA(LG(F6))) Z   &my_mtw LS(LA(LG(F7))) X   &my_mtw LC(C) C   &my_mtw LC(V) V         &kp B                                              &kp N                &kp M             &kp COMMA         &kp DOT            &kp FSLH              &mo LAYER_Block
                                                                                            &none                   &lt LAYER_Symb BSPC    &kp LSHFT       &kp SPACE   &lt LAYER_Subl RET   &none
            >;
        };


        layer_Nav {
                  display-name = "NAVI";
            bindings = <
//    ┌──────────────────┬─────┬───────────────────────────┬───────────────────────────┬───────────────────────────┬───────────────────────────┐                                        ┌──────────────────┬──────────────────┬────────────────┬──────────────────┬───────────────────────────┬─────┐
//    │ mo laltYER_Block │     │ lgui(lctl(lalt(lsft(0)))) │          lgui([)          │          lgui(])          │ lgui(lctl(lalt(lsft(D)))) │                                        │ lalt(lsft(left)) │ lalt(lsft(down)) │ lalt(lsft(up)) │ lalt(lsft(rght)) │                           │     │
//    ├──────────────────┼─────┼───────────────────────────┼───────────────────────────┼───────────────────────────┼───────────────────────────┤                                        ├──────────────────┼──────────────────┼────────────────┼──────────────────┼───────────────────────────┼─────┤
//    │                  │     │ lgui(lctl(lalt(lsft(=)))) │ lgui(lctl(lalt(lsft(9)))) │ lgui(lctl(lalt(lsft(W)))) │ lgui(lctl(lalt(lsft(G)))) │                                        │       left       │       down       │       up       │       rght       │ lgui(lctl(lalt(lsft(;)))) │     │
//    ├──────────────────┼─────┼───────────────────────────┼───────────────────────────┼───────────────────────────┼───────────────────────────┤                                        ├──────────────────┼──────────────────┼────────────────┼──────────────────┼───────────────────────────┼─────┤
//    │                  │     │                           │                           │ lgui(lctl(lalt(lsft(B)))) │                           │                                        │                  │                  │                │                  │                           │     │
//    └──────────────────┴─────┴───────────────────────────┴───────────────────────────┼───────────────────────────┼───────────────────────────┼──────┐   ┌─────────────────────────────┼──────────────────┼──────────────────┼────────────────┴──────────────────┴───────────────────────────┴─────┘
//                                                                                     │                           │           rclk            │ mclk │   │ lgui(lctl(lalt(lsft(tab)))) │       caps       │                  │
//                                                                                     └───────────────────────────┴───────────────────────────┴──────┘   └─────────────────────────────┴──────────────────┴──────────────────┘
  &mo LAYER_Block   &trans   &kp LG(LC(LA(LS(N0))))      &kp LG(LBKT)             &kp LG(RBKT)            &kp LG(LC(LA(LS(D))))                                             &kp LA(LS(LEFT))   &kp LA(LS(DOWN))   &kp LA(LS(UP))   &kp LA(LS(RIGHT))   &trans                     &trans
  &trans            &trans   &kp LG(LC(LA(LS(EQUAL))))   &kp LG(LC(LA(LS(N9))))   &kp LG(LC(LA(LS(W))))   &kp LG(LC(LA(LS(G))))                                             &kp LEFT           &kp DOWN           &kp UP           &kp RIGHT           &kp LG(LC(LA(LS(SEMI))))   &trans
  &trans            &trans   &trans                      &trans                   &kp LG(LC(LA(LS(B))))   &trans                                                            &trans             &trans             &trans           &trans              &trans                     &trans
                                                                                  &trans                  &mkp RCLK               &mkp MCLK       &kp LG(LC(LA(LS(TAB))))   &kp CAPSLOCK       &trans
            >;
        };

        layer_Symb {
            display-name = "SYMB";
            bindings = <
//    ┌──────────────────┬─────────┬─────────┬─────────┬─────────┬─────────┐               ┌─────────┬─────────┬─────────┬─────────┬─────────┬──────────────────┐
//    │ mo laltYER_Block │ lsft(1) │ lsft(2) │ lsft(3) │ lsft(4) │ lsft(5) │               │ lsft(6) │ lsft(7) │ lsft(8) │ lsft(9) │ lsft(0) │ mo laltYER_Block │
//    ├──────────────────┼─────────┼─────────┼─────────┼─────────┼─────────┤               ├─────────┼─────────┼─────────┼─────────┼─────────┼──────────────────┤
//    │ mo laltYER_Block │    1    │    2    │    3    │    4    │    5    │               │    6    │    7    │    8    │    9    │    0    │ mo laltYER_Block │
//    ├──────────────────┼─────────┼─────────┼─────────┼─────────┼─────────┤               ├─────────┼─────────┼─────────┼─────────┼─────────┼──────────────────┤
//    │ mo laltYER_Block │ lsft(,) │ lsft(.) │ lsft(/) │    [    │    ]    │               │ lsft([) │ lsft(]) │    ,    │    .    │    /    │ mo laltYER_Block │
//    └──────────────────┴─────────┴─────────┴─────────┼─────────┼─────────┼─────┐   ┌─────┼─────────┼─────────┼─────────┴─────────┴─────────┴──────────────────┘
//                                                     │         │         │     │   │     │         │         │
//                                                     └─────────┴─────────┴─────┘   └─────┴─────────┴─────────┘
  &mo LAYER_Block   &kp LS(N1)      &kp LS(N2)    &kp LS(N3)     &kp LS(N4)   &kp LS(N5)                         &kp LS(N6)     &kp LS(N7)     &kp LS(N8)   &kp LS(N9)   &kp LS(N0)   &mo LAYER_Block
  &mo LAYER_Block   &kp N1          &kp N2        &kp N3         &kp N4       &kp N5                             &kp N6         &kp N7         &kp N8       &kp N9       &kp N0       &mo LAYER_Block
  &mo LAYER_Block   &kp LS(COMMA)   &kp LS(DOT)   &kp LS(FSLH)   &kp LBKT     &kp RBKT                           &kp LS(LBKT)   &kp LS(RBKT)   &kp COMMA    &kp DOT      &kp FSLH     &mo LAYER_Block
                                                                 &trans       &trans       &trans       &trans   &trans         &trans
            >;
        };


        layer_Subl {
            display-name = "SUBL";
            bindings = <
//    ┌─────┬─────┬────────────────────┬─────┬────────────────────┬──────────────────────┐               ┌─────┬─────┬─────┬────────────────┬─────┬─────┐
//    │     │     │  mo laltYER_Work   │     │ mo laltYER_Raycast │   mo laltYER_Sesss   │               │     │     │     │ mo laltYER_Obs │     │     │
//    ├─────┼─────┼────────────────────┼─────┼────────────────────┼──────────────────────┤               ├─────┼─────┼─────┼────────────────┼─────┼─────┤
//    │     │     │ mo laltYER_Letters │     │                    │                      │               │     │     │     │                │     │     │
//    ├─────┼─────┼────────────────────┼─────┼────────────────────┼──────────────────────┤               ├─────┼─────┼─────┼────────────────┼─────┼─────┤
//    │     │     │                    │     │                    │ mo laltYER_Bluetooth │               │     │     │     │                │     │     │
